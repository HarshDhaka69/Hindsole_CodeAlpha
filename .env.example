# Copy this file to .env and fill in real values for your environment.
# .env is read by django-environ in config/settings.py; it is NOT
# committed to version control.

# A long, random, secret string. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=django-insecure-change-me

# "True" or "False" — never run with DEBUG=True in production.
DJANGO_DEBUG=True

# Comma-separated list of allowed hosts.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Leave unset to fall back to a local SQLite file automatically.
# Example for PostgreSQL:
# DATABASE_URL=postgres://hindsole_user:password@localhost:5432/hindsole

DJANGO_TIME_ZONE=Asia/Kolkata

# Commerce settings
TAX_RATE=0.08
FREE_SHIPPING_THRESHOLD=150.00
STANDARD_SHIPPING_COST=9.00
CURRENCY_SYMBOL=USD

# Email (powers password-reset emails). Leave EMAIL_HOST unset to print
# emails to the console instead — fine for local development. Set these
# to use a real mail server (e.g. SendGrid, Postmark, Gmail SMTP) in
# production:
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-smtp-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=HINDSOLE <noreply@yourdomain.com>
